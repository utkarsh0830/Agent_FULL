# LLM (choose one provider)
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.0-flash
GOOGLE_API_KEY=
OPENAI_API_KEY=

# AWS (for S3 FOCUS ingestion)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
FOCUS_S3_BUCKET=

# Connectors (leave blank to use mock data)
OPENCOST_API_URL=
INFRACOST_API_KEY=
CUSTODIAN_POLICY_DIR=./policies

# Database
DATABASE_PATH=./data/finops.db

# Feature flags
USE_MOCK_DATA=true
